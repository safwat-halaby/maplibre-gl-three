{
    "version": 8,
    "sources": {
        "washington": {
            "type": "geojson",
            "data": "/datasets/washington.geojson.json"
        },
        "natural-earth-web-mercator": {
            "type": "raster",
            "tiles": [
                "/datasets/natural-earth/WebMercatorQuad/{z}/{x}/{y}.png"
            ],
            "minzoom": 0,
            "maxzoom": 6,
            "scheme": "xyz",
            "tileSize": 256
        }
    },
    "layers": [
        {
            "id": "background-web-mercator",
            "type": "raster",
            "source": "natural-earth-web-mercator",
            "paint": {
                "raster-opacity": 1
            }
        },
        {
            "id": "washington-lines",
            "type": "line",
            "source": "washington",
            "paint": {
                "line-color": "#f0f",
                "line-opacity": 1,
                "line-width": 3
            }
        },
        {
            "id": "washington-webmercator-marker",
            "type": "symbol",
            "source": "washington",
            "filter": [
                "==",
                ["get", "name_english"],
                "Vancouver"
            ],
             "layout": {
                "icon-image": "maplibre-webmercator"
             }
        }
    ]
}